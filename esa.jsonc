{
  // 阿里云 ESA Pages 部署配置（纯静态站点，无边缘函数）
  // 文档：https://help.aliyun.com/zh/edge-security-acceleration/esa/user-guide/build-pages
  "name": "mason-nora-wedding",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "assets": {
    // 构建产物目录：build.mjs 把用到的文件复制到这里
    "directory": "./dist",
    // 单页站点：未匹配到的路径回退到 index.html
    "notFoundStrategy": "singlePageApplication"
  }
}
